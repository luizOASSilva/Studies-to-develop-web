{
  "compilerOptions": {
    /* Ambiente */
    "target": "ES2022",
    "module": "amd",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "types": ["node"],

    "allowJs": true,
    "rootDir": "src",
    "outFile": "dist/bundle.js",
    // "outDir": "dist",        

    /* Decorators */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    /* Qualidade */
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Debug */
    "sourceMap": true,

    /* Compatibilidade */
    "esModuleInterop": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}