{
  "compilerOptions": {
    /* Ambiente */
    "target": "ES2022",
    "module": "amd",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "types": ["node"],

    "allowJs": true,
    "rootDir": "../Aula 4 - Utilizando biblioteca de terceiros/src",
    "outFile": "../Aula 4 - Utilizando biblioteca de terceiros/dist/bundle.js",
    // "outDir": "dist",        

    /* Decorators */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    /* Qualidade */
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Debug */
    "sourceMap": true,

    /* Compatibilidade */
    "esModuleInterop": true
  },
  "include": ["../Aula 4 - Utilizando biblioteca de terceiros/src"],
  "exclude": ["../Aula 4 - Utilizando biblioteca de terceiros/node_modules"]
}