{
  "compilerOptions": {
    /* Ambiente */
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],

    /* Diretórios */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Decorators */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    /* Qualidade */
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Debug */
    "sourceMap": true,

    /* Compatibilidade */
    "esModuleInterop": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}